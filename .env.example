CREATIVE_DEBUG=false
CREATIVE_LOG_LEVEL=INFO

# Base de datos
CREATIVE_DATABASE__POSTGRES_URL=postgresql+asyncpg://engine:engine_dev@localhost:5432/creative_engine
CREATIVE_DATABASE__NEO4J_URI=bolt://localhost:7687
CREATIVE_DATABASE__NEO4J_USER=neo4j
CREATIVE_DATABASE__NEO4J_PASSWORD=neo4j_dev
CREATIVE_DATABASE__REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN RECOMENDADA: solo Gemini (free tier estable)
# ─────────────────────────────────────────────────────────────
# Un único proveedor, sin routing. Lento pero fiable en free tier.
# BASE_URL debe acabar en barra. Modelo: alias auto-actualizado.
CREATIVE_LLM__DEFAULT__NAME=gemini
CREATIVE_LLM__DEFAULT__API_KEY=tu-gemini-api-key
CREATIVE_LLM__DEFAULT__BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CREATIVE_LLM__DEFAULT__MODEL=gemini-flash-latest
CREATIVE_LLM__DEFAULT__MAX_CONCURRENT=2
CREATIVE_LLM__DEFAULT__MIN_INTERVAL_SECONDS=4.0

# --- Multi-proveedor (opcional, si tienes más claves válidas) ---
# Añade proveedores extra y enruta por rol con failover. Ver README.
# CREATIVE_LLM__GROQ__API_KEY=gsk_...
# CREATIVE_LLM__GROQ__BASE_URL=https://api.groq.com/openai/v1
# CREATIVE_LLM__GROQ__MODEL=llama-3.3-70b-versatile
# CREATIVE_ROUTING_SPEC=evaluator=groq,default;generator=default,groq
# Evolución
CREATIVE_EVOLUTION__MUTATION_RATE=0.4
CREATIVE_EVOLUTION__CROSSOVER_RATE=0.25
CREATIVE_EVOLUTION__RANDOM_INJECTION_RATE=0.1
CREATIVE_EVOLUTION__MAX_GENERATION_TIME_SECONDS=300
