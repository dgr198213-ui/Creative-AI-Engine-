CREATIVE_DEBUG=false
CREATIVE_LOG_LEVEL=INFO

# Base de datos
CREATIVE_DATABASE__POSTGRES_URL=postgresql+asyncpg://engine:engine_dev@localhost:5432/creative_engine
CREATIVE_DATABASE__NEO4J_URI=bolt://localhost:7687
CREATIVE_DATABASE__NEO4J_USER=neo4j
CREATIVE_DATABASE__NEO4J_PASSWORD=neo4j_dev
CREATIVE_DATABASE__REDIS_URL=redis://localhost:6379/0

# LLM (cualquier API OpenAI-compatible)
CREATIVE_LLM__DEFAULT__NAME=openai
CREATIVE_LLM__DEFAULT__API_KEY=sk-your-key-here
CREATIVE_LLM__DEFAULT__MODEL=gpt-4o-mini
CREATIVE_LLM__DEFAULT__MAX_TOKENS=4096
CREATIVE_LLM__DEFAULT__TEMPERATURE=0.8
CREATIVE_LLM__DEFAULT__MAX_CONCURRENT=5

# --- Ejemplo: Google Gemini (capa compatible con OpenAI) ---
# La BASE_URL debe acabar en barra. Usa el alias auto-actualizado
# 'gemini-flash-latest' para no depender de nombres que Google retira.
# El free tier tiene rate limits estrictos: baja MAX_CONCURRENT y sube
# MIN_INTERVAL_SECONDS para no saturarlo.
# CREATIVE_LLM__DEFAULT__NAME=gemini
# CREATIVE_LLM__DEFAULT__API_KEY=tu-gemini-api-key
# CREATIVE_LLM__DEFAULT__BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CREATIVE_LLM__DEFAULT__MODEL=gemini-flash-latest
# CREATIVE_LLM__DEFAULT__MAX_CONCURRENT=2
# CREATIVE_LLM__DEFAULT__MIN_INTERVAL_SECONDS=4.0

# --- Ejemplo: Groq (rápido, free tier generoso, sin tarjeta) ---
# Ideal para el rol 'evaluator' (muchas llamadas cortas). console.groq.com
# CREATIVE_LLM__GROQ__NAME=groq
# CREATIVE_LLM__GROQ__API_KEY=gsk_tu-groq-key
# CREATIVE_LLM__GROQ__BASE_URL=https://api.groq.com/openai/v1
# CREATIVE_LLM__GROQ__MODEL=llama-3.3-70b-versatile
# CREATIVE_LLM__GROQ__MAX_CONCURRENT=4
# CREATIVE_LLM__GROQ__MIN_INTERVAL_SECONDS=2.0

# --- Enrutamiento por rol con failover ---
# Formato: "rol=proveedor1,proveedor2;..."  (los nombres son los de arriba)
# El generador usa un modelo creativo; los evaluadores uno rápido; si un
# proveedor se satura (rate limit/503), salta al siguiente de su lista.
# Vacío = todos los roles usan el primer proveedor definido.
# CREATIVE_ROUTING_SPEC=generator=gemini,groq;evaluator=groq,gemini;writer=gemini

# Evolución
CREATIVE_EVOLUTION__MUTATION_RATE=0.4
CREATIVE_EVOLUTION__CROSSOVER_RATE=0.25
CREATIVE_EVOLUTION__RANDOM_INJECTION_RATE=0.1
CREATIVE_EVOLUTION__MAX_GENERATION_TIME_SECONDS=300
