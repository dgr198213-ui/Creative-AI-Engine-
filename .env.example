CREATIVE_DEBUG=false
CREATIVE_LOG_LEVEL=INFO

# Auditoría C1: sin esta clave, la API queda abierta (uso local/tests).
# En cuanto el dominio sea público (Railway), defínela — exige la
# cabecera X-API-Key (o ?api_key= en enlaces de descarga) en /api/v1/*.
# CREATIVE_API_KEY=una-clave-larga-y-aleatoria

# Base de datos
CREATIVE_DATABASE__POSTGRES_URL=postgresql+asyncpg://engine:engine_dev@localhost:5432/creative_engine
CREATIVE_DATABASE__NEO4J_URI=bolt://localhost:7687
CREATIVE_DATABASE__NEO4J_USER=neo4j
CREATIVE_DATABASE__NEO4J_PASSWORD=neo4j_dev
CREATIVE_DATABASE__REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────
# CONFIGURACIÓN RECOMENDADA: solo Gemini (free tier estable)
# ─────────────────────────────────────────────────────────────
# Un único proveedor, sin routing. Lento pero fiable en free tier.
# BASE_URL debe acabar en barra. Modelo: alias auto-actualizado.
CREATIVE_LLM__DEFAULT__NAME=gemini
CREATIVE_LLM__DEFAULT__API_KEY=tu-gemini-api-key
CREATIVE_LLM__DEFAULT__BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CREATIVE_LLM__DEFAULT__MODEL=gemini-flash-latest
CREATIVE_LLM__DEFAULT__MAX_CONCURRENT=2
CREATIVE_LLM__DEFAULT__MIN_INTERVAL_SECONDS=4.0

# --- Multi-proveedor (opcional, si tienes más claves válidas) ---
# Añade proveedores extra y enruta por rol con failover. Ver README.
#
# Z.ai (GLM) — dos modelos gratis, OpenAI-compatible, sin tarjeta:
# glm-4.5-flash y glm-4.7-flash (este último con 200K de contexto).
# CREATIVE_LLM__ZAI__NAME=zai
# CREATIVE_LLM__ZAI__API_KEY=tu-zai-api-key
# CREATIVE_LLM__ZAI__BASE_URL=https://api.z.ai/api/paas/v4/
# CREATIVE_LLM__ZAI__MODEL=glm-4.5-flash
# CREATIVE_LLM__ZAI__MAX_CONCURRENT=2
# CREATIVE_LLM__ZAI__MIN_INTERVAL_SECONDS=3.0
# IMPORTANTE con GLM: desactiva el modo razonador (lentísimo en free tier,
# provoca timeouts en evaluación). Sin esto, el modelo 'piensa' >60s:
# CREATIVE_LLM__ZAI__EXTRA_BODY={"thinking":{"type":"disabled"}}
#
# Groq (open-source, rápido):
# CREATIVE_LLM__GROQ__API_KEY=gsk_...
# CREATIVE_LLM__GROQ__BASE_URL=https://api.groq.com/openai/v1
# CREATIVE_LLM__GROQ__MODEL=llama-3.3-70b-versatile
#
# OpenAI real (no un compatible): modelos recientes rechazan max_tokens
# con 400 invalid_request_error, exigen max_completion_tokens. TYPE=openai
# activa ese parámetro; el resto de proveedores no lo necesitan.
# CREATIVE_LLM__TERRA__API_KEY=sk-...
# CREATIVE_LLM__TERRA__MODEL=gpt-5.6-sol
# CREATIVE_LLM__TERRA__TYPE=openai
#
# Enrutado por rol con failover (nombres = los definidos arriba):
# CREATIVE_ROUTING_SPEC=generator=default,zai;evaluator=zai,default;writer=default
# Evolución
CREATIVE_EVOLUTION__MUTATION_RATE=0.4
CREATIVE_EVOLUTION__CROSSOVER_RATE=0.25
CREATIVE_EVOLUTION__RANDOM_INJECTION_RATE=0.1
CREATIVE_EVOLUTION__MAX_GENERATION_TIME_SECONDS=300
#
# Guardrails de la API pública (auditoría de seguridad): tope de
# población×generaciones por request y rate limit por IP en /evolution/*.
# CREATIVE_EVOLUTION__MAX_REQUESTED_EVALUATIONS=2000
# CREATIVE_EVOLUTION__RATE_LIMIT_PER_MINUTE=10
# CREATIVE_EVOLUTION__RATE_LIMIT_WINDOW_SECONDS=60
